# Copy this file to .env and fill in your CoinStats Open API key.
# Get one at https://openapi.coinstats.app/

# Only VITE_-prefixed vars are exposed to the browser bundle (Vite).
# NOTE: this is a pure-frontend app, so the key ships in the built JS and
# is publicly visible. Use a key you can rate-limit / rotate.
VITE_COINSTATS_API_KEY=your_coinstats_api_key_here
